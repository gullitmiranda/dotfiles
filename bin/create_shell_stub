#!/usr/bin/env bash
# create_shell_stub - Creates or updates shell configuration with tagged content blocks
# Usage: create_shell_stub <target_file> [options]
#
# The content is read from stdin, making it easy to use with heredoc

# shellcheck disable=SC2155

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

# Default settings
DRY_RUN=false
VERBOSE=false
BIN_NAME=$(basename "$0")

# Default block tag name
BLOCK_TAG="autogenerated-dotfiles-block"

# Tags to mark the managed content block
START_TAG="## <${BLOCK_TAG}>"
END_TAG="## </${BLOCK_TAG}>"

# Print usage information
usage() {
	cat <<EOFM
Usage: ${BIN_NAME} <target_file> [options]

Arguments:
  <target_file>    Path to the target configuration file (e.g., ~/.config/fish/config.fish)

Options:
  --block-tag=TAG  Set the block tag name (default: autogenerated-dotfiles-block)
  --dry-run        Show what would be done without making changes
  --verbose        Show more detailed output
  -h, --help       Show this help message

The stub content is read from stdin. Use a heredoc to provide the content.

Examples:
  ${BIN_NAME} ~/.config/fish/config.fish <<- 'EOF'
  set -gx DOTFILES_DIR "\$HOME/dotfiles"
  source \$DOTFILES_DIR/shells/fish/config.fish
	EOF

  ${BIN_NAME} ~/.zshrc --block-tag=my-custom-tag <<- 'EOF'
  export DOTFILES_DIR="\$HOME/my-dotfiles"
  source \$DOTFILES_DIR/shells/zsh/.zshrc
	EOF
EOFM
	exit 0
}

# Log messages with colors
log() {
	local level="$1"
	local message="$2"
	local color=""

	case "${level}" in
	info) color="${BLUE}" ;;
	success) color="${GREEN}" ;;
	warning) color="${YELLOW}" ;;
	error) color="${RED}" ;;
	*) color="${RESET}" ;;
	esac

	printf "${color}${BOLD}[create_shell_stub]${RESET} ${color}%s${RESET}\n" "${message}"
}

# Execute or print a command
execute() {
	local cmd="$*"

	if [[ ${VERBOSE} == true ]]; then
		log "info" "Executing: ${cmd}"
	fi

	if [[ ${DRY_RUN} == true ]]; then
		log "info" "Would execute: ${cmd}"
		return 0
	fi

	eval "${cmd}"
	return $?
}

# Parse command line arguments
parse_args() {
	# Check for minimum arguments
	if [[ $# -lt 1 ]]; then
		log "error" "Not enough arguments"
		usage
	fi

	# Get the required positional argument and expand tilde
	TARGET_FILE="${1/#\~/${HOME}}"
	shift

	# Process optional arguments
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--block-tag=*)
			BLOCK_TAG="${1#*=}"
			# Update tags with the new block tag name
			START_TAG="## <${BLOCK_TAG}>"
			END_TAG="## </${BLOCK_TAG}>"
			;;
		--dry-run)
			DRY_RUN=true
			;;
		--verbose)
			VERBOSE=true
			;;
		-h | --help)
			usage
			;;
		*)
			log "error" "Unknown option: $1"
			usage
			;;
		esac
		shift
	done
}

# Main execution
main() {
	parse_args "$@"

	# Read stub content from stdin
	log "info" "Reading stub content from stdin..."
	local content
	content=$(cat)

	# Create parent directory if it doesn't exist
	if [[ ! -d "$(dirname "${TARGET_FILE}")" ]]; then
		log "info" "Creating directory: $(dirname "${TARGET_FILE}")"
		if [[ ${DRY_RUN} == false ]]; then
			mkdir -p "$(dirname "${TARGET_FILE}")"
		fi
	fi

	# Create temporary files for the operation
	local temp_file
	temp_file=$(mktemp)

	if [[ -f ${TARGET_FILE} ]]; then
		if (grep -F -q "${START_TAG}" "${TARGET_FILE}") && (grep -F -q "${END_TAG}" "${TARGET_FILE}"); then
			# File exists with our tagged block, update it
			log "info" "Updating existing tagged block in ${TARGET_FILE}"

			if [[ ${DRY_RUN} == false ]]; then
				# Create a temporary file
				local temp_before=$(mktemp)
				local temp_after=$(mktemp)

				# Get line numbers for the tags
				local start_line=$(grep -n -F "${START_TAG}" "${TARGET_FILE}" | head -n 1 | cut -d':' -f1)
				local end_line=$(grep -n -F "${END_TAG}" "${TARGET_FILE}" | head -n 1 | cut -d':' -f1)

				# Extract content before the start tag
				if [[ ${start_line} -gt 1 ]]; then
					head -n $((start_line - 1)) "${TARGET_FILE}" >"${temp_before}"
				else
					touch "${temp_before}"
				fi

				# Extract content after the end tag
				local total_lines=$(wc -l <"${TARGET_FILE}")
				if [[ ${end_line} -lt ${total_lines} ]]; then
					tail -n $((total_lines - end_line)) "${TARGET_FILE}" >"${temp_after}"
				else
					touch "${temp_after}"
				fi

				# Combine all parts
				{
					cat "${temp_before}"
					echo "${START_TAG}"
					echo "${content}"
					echo "${END_TAG}"
					cat "${temp_after}"
				} >"${temp_file}"

				# Clean up temporary files
				rm "${temp_before}" "${temp_after}"

				# Replace the original file
				mv "${temp_file}" "${TARGET_FILE}"
				log "success" "Updated dotfiles configuration block in ${TARGET_FILE}"
			fi
		else
			# File exists but doesn't have our block, append it
			log "info" "Appending new tagged block to ${TARGET_FILE}"

			if [[ ${DRY_RUN} == false ]]; then
				# Ensure file ends with newline
				if [[ -s ${TARGET_FILE} ]]; then
					last_char=$(tail -c 1 "${TARGET_FILE}")
					line_count=$(echo "${last_char}" | wc -l)
					if [[ ${line_count} -eq 0 ]]; then
						echo "" >>"${TARGET_FILE}"
					fi
				fi

				# Append our block
				{
					echo "${START_TAG}"
					echo "${content}"
					echo "${END_TAG}"
				} >>"${TARGET_FILE}"
				log "success" "Added dotfiles configuration block to ${TARGET_FILE}"
			fi
		fi
	else
		# File doesn't exist, create it
		log "info" "Creating new file with tagged block at ${TARGET_FILE}"

		if [[ ${DRY_RUN} == false ]]; then
			{
				echo "${START_TAG}"
				echo "${content}"
				echo "${END_TAG}"
			} >"${TARGET_FILE}"
			log "success" "Created ${TARGET_FILE} with dotfiles configuration block"
		fi
	fi

	# Clean up
	[[ -f ${temp_file} ]] && rm "${temp_file}"

	log "info" "You can add your own customizations outside the tagged block"
}

# Run the script
main "$@"
