#!/bin/bash

# Parse arguments for debug flag
DEBUG=0
for arg in "$@"; do
  case "$arg" in
    --debug)
      DEBUG=1
      ;;
    *)
      # Ignore unknown flags
      ;;
  esac
done

# Enable debug if GIT_TRACE is set
if [[ "${GIT_TRACE}" == "1" ]]; then
  DEBUG=1
fi

# Determine the log file path based on the operating system
if [[ "$(uname || true)" == "Darwin" ]]; then
  # macOS
  logfile="$HOME/Library/Logs/git-credential-env-helper.log"
else
  # Linux or other systems
  logfile="$HOME/.local/log/git-credential-env-helper.log"
fi

# Override logfile if GIT_CREDENTIAL_ENV_HELPER_LOG_FILE is set
if [[ -n "${GIT_CREDENTIAL_ENV_HELPER_LOG_FILE}" ]]; then
  logfile="${GIT_CREDENTIAL_ENV_HELPER_LOG_FILE}"
fi

reset_log() {
  if [[ "${DEBUG}" == "1" ]]; then
    mkdir -p "$(dirname "${logfile}")"
    echo "" >"${logfile}"
  fi
}

log() {
  if [[ "${DEBUG}" == "1" ]]; then
    echo "$*" >>"${logfile}"
  fi
}

reset_log
log "<<< Start git-credential-env-helper >>>"

# Main logic
############

if [[ $1 == "get" ]]; then
  log "Command: get"
  log "args: $*"

  while IFS='=' read -r key value; do
    log "Read line: ${key}=${value}"

    case "${key}" in
      # url) url="${value}" ;;
      # password) password="${value}" ;;
      # protocol) protocol="${value}" ;;
      username) username="${value}" ;;
      host) host="${value}" ;;
      path) path="${value}" ;;
      *)
        # log "Unknown key: ${key}"
        ;;
    esac
  done

  # if the has the org cloudwalk, use GITHUB_TOKEN
  if [[ ${host} == github.com && ${path} == cloudwalk* ]]; then
    token=${GITHUB_TOKEN_CLOUDWALK:-${GITHUB_TOKEN}}
    log "Using GITHUB_TOKEN_CLOUDWALK or GITHUB_TOKEN for CloudWalk"

    if [[ -z ${token} ]]; then
      log "GITHUB_TOKEN_CLOUDWALK or GITHUB_TOKEN is not set"
      exit 1
    fi

    echo "username=${username:-git}"
    echo "password=${token}"
    exit 0
  fi

  # # force ssh protocol when https is used
  # if [[ ${protocol} == https ]]; then
  #   url="ssh://${username:-git}:${password}@${host}/${path}"

  #   # log the url with password masked
  #   log "url: ${url//${password}/****}"

  #   echo "url=${url}"
  #   exit 0
  # fi
fi

# if we reach this point, the url is not handled by this helper
exit 1

log "<<< End git-credential-env-helper >>>"
