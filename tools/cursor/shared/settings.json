{
  // ── cursor-sync ────────────────────────────────────────────────────────────
  // Backup & sync via private GitHub Gist. See tools/cursor/README.md for setup.
  // Only syncs the default (Work) profile. GitHub token is configured separately
  // via "Cursor Sync: Configure GitHub" in the Command Palette.
  "cursorSync.schedule.enabled": true,
  "cursorSync.schedule.intervalMin": 30,
  "cursorSync.safeMode": true,
  "cursorSync.syncExtensions.autoInstall": true,
  "cursorSync.syncExtensions.autoUninstall": false,
  // ──────────────────────────────────────────────────────────────────────────
  "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 13,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "editor.rulers": [
    100
  ],
  "editor.minimap.enabled": false,
  "editor.wordWrap": "off",
  "editor.cursorBlinking": "smooth",
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "terminal.integrated.fontFamily": "JetBrains Mono, MesloLGS NF, monospace",
  "terminal.integrated.fontSize": 13,
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  // "window.title": "Cursor [Work] ${separator} ${activeEditorShort}${separator}${rootName}",
  "git.defaultCloneDirectory": "~/code/",
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.composer.usageSummaryDisplay": "always",
  "application.shellEnvironmentResolutionTimeout": 20,
  "cursor.cpp.disabledLanguages": [],
  "workbench.activityBar.orientation": "vertical",
  "workbench.colorTheme": "Catppuccin Frappé",
  "terminal.integrated.scrollback": 10000,
  "files.exclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "files.watcherExclude": {
    "*.hcl": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "editor.defaultFormatter": "trunk.io",
  "redhat.telemetry.enabled": false,
  "files.associations": {
    "keybindings.json": "jsonc",
    "keybindings.*.json": "jsonc",
    "settings.json": "jsonc",
    "settings.*.json": "jsonc",
    "**/templates/**/*.yaml": "helm",
    "**/templates/**/*.tpl": "helm",
    ".prettierignore": "ignore",
    ".eslintignore": "ignore",
    ".npmignore": "ignore",
    "*.hcl": "terragrunt"
  },
  "[helm]": {
    "editor.formatOnSave": false
  },
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "trunk.autoInit": false,
  "git.openRepositoryInParentFolders": "never",
  "gitlens.views.scm.grouped.hiddenViews": {
    "commits": false,
    "worktrees": true,
    "branches": false,
    "remotes": false,
    "stashes": false,
    "tags": false,
    "contributors": false,
    "repositories": true,
    "fileHistory": false,
    "launchpad": false,
    "searchAndCompare": false
  },
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "disabled"
  },
  "terraform.languageServer.enable": true,
  "window.openFoldersInNewWindow": "on",
  "projectManager.git.baseFolders": [
    "~/code/"
  ],
  "terminal.external.osxExec": "iTerm.app",
  "githubPullRequests.pullBranch": "never"
}
